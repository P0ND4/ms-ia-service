# Server
NODE_ENV=development
PORT=3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/ia-service-local
MONGO_DB_NAME=ia-service

# IA config
IA_TENANT_CONFIG_PATH=src/app/bootstrap/tenant-agents.config.json
IA_SESSION_MEMORY_LIMIT=12
IA_GUARDRAIL_INPUT_BLOCKLIST=credit card,tarjeta de credito,password,contrasena
IA_GUARDRAIL_OUTPUT_BLOCKLIST=ssn,security code,cvv,token secreto
IA_SIMULATE_PROVIDER_FAILURES=
IA_DEFAULT_INPUT_COST_PER_1K_TOKENS_USD=0.0015
IA_DEFAULT_OUTPUT_COST_PER_1K_TOKENS_USD=0.0020